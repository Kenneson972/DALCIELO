# Stripe (mode test pour le dev local)
# Clés : https://dashboard.stripe.com/test/apikeys (activer le mode Test)
STRIPE_SECRET_KEY=sk_test_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
# En local : fourni par la Stripe CLI (npm run stripe:webhook). En prod : signing secret du webhook Dashboard.
STRIPE_WEBHOOK_SECRET=whsec_...

# Supabase – base de données (commandes, stocks, réservations)
# Créer les tables : exécuter database/supabase/001_*.sql, 002_*.sql, 003_*.sql dans SQL Editor
# Vérifier : http://localhost:3000/api/orders/health (doit afficher ok: true)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# n8n <-> API secrets
N8N_ADMIN_API_KEY=your-strong-secret
# Webhook CieloBot (chatbot site → n8n DeepSeek AI)
N8N_CHATBOT_WEBHOOK_URL=https://kenneson.app.n8n.cloud/webhook/celiobot
# Webhook n8n appelé quand equipe de Dal Cielo valide une commande (→ le bot notifie le client)
# Format : https://your-n8n.instance/webhook/order-validated
N8N_ORDER_NOTIFY_WEBHOOK_URL=

# Webhook n8n pour générer et envoyer le reçu PDF (après paiement Stripe)
N8N_RECEIPT_WEBHOOK_URL=https://kenneson.app.n8n.cloud/webhook/receipt-pizza-dal-cielo
# Secret pour que n8n puisse uploader le PDF sur l’API (même valeur à mettre dans n8n en-tête x-receipt-secret)
RECEIPT_UPLOAD_SECRET=your-receipt-upload-secret

# App URL
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Logs JSON détaillés pour /api/delivery-fee (stdout) : input, label BAN, coords, distances, fee
# DELIVERY_FEE_DEBUG=1

# (Retiré) NEXT_PUBLIC_ORDERING_ENABLED — la commande en ligne n’est plus coupée par une variable d’env.
# Seuls le lundi (Martinique) et le réglage « four » côté admin peuvent bloquer la prise de commande.

# Admin PIN – protection /admin et /api/admin/*
# En production : définir uniquement ADMIN_PIN. Ne pas utiliser NEXT_PUBLIC_* pour le PIN en prod.
ADMIN_PIN=your-secret-pin
